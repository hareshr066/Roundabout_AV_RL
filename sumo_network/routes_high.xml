<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">

    <!-- HDV: Krauss model with human-driver parameters -->
    <vType id="passenger_car"
           carFollowModel="Krauss"
           length="4.8" minGap="2.5" maxSpeed="13.89"
           accel="2.2" decel="4.0" emergencyDecel="9.0"
           sigma="0.7" tau="1.4" speedDev="0.15"
           lcStrategic="1.5" lcAssertive="0.8" lcPushy="0.7"
           guiShape="passenger" color="0.12,0.56,1.0"/>

    <!-- AV: IDM model, deterministic, tight platoon spacing -->
    <vType id="av_car"
           carFollowModel="IDM"
           length="4.8" minGap="1.5" maxSpeed="13.89"
           accel="3.0" decel="4.5" emergencyDecel="9.0"
           sigma="0.0" tau="0.6" speedDev="0.0"
           guiShape="passenger/sedan" color="0.0,0.78,0.36"/>

    <!-- EGO AV: PPO agent - Red -->
    <vType id="ego_av"
           carFollowModel="IDM"
           length="4.8" minGap="1.5" maxSpeed="13.89"
           accel="3.0" decel="4.5" emergencyDecel="9.0"
           sigma="0.0" tau="0.6" speedDev="0.0"
           guiShape="passenger/sedan" color="1.0,0.0,0.0"/>

    <route id="r_N_E" edges="entry_N circ_N_W circ_W_S circ_S_E exit_E"/>
    <route id="r_N_S" edges="entry_N circ_N_W circ_W_S exit_S"/>
    <route id="r_W_S" edges="entry_W circ_W_S exit_S"/>
    <route id="r_E_N" edges="entry_E circ_E_N exit_N"/>
    <route id="r_W_N" edges="entry_W circ_W_S circ_S_E circ_E_N exit_N"/>
    <route id="r_E_S" edges="entry_E circ_E_N circ_N_W circ_W_S exit_S"/>
    <route id="r_S_N" edges="entry_S circ_S_E circ_E_N exit_N"/>
    <route id="r_S_W" edges="entry_S circ_S_E exit_E"/>

    <!-- HIGH preset scaled flow rates -->
    <flow id="flow_N_E" type="passenger_car" route="r_N_E" begin="0" end="3600" vehsPerHour="800" departLane="free" departSpeed="max"/>
    <flow id="flow_N_S" type="passenger_car" route="r_N_S" begin="0" end="3600" vehsPerHour="800" departLane="free" departSpeed="max"/>
    <flow id="flow_W_S" type="passenger_car" route="r_W_S" begin="0" end="3600" vehsPerHour="800" departLane="free" departSpeed="max"/>
    <flow id="flow_E_N" type="passenger_car" route="r_E_N" begin="0" end="3600" vehsPerHour="800" departLane="free" departSpeed="max"/>
    <flow id="flow_W_N" type="passenger_car" route="r_W_N" begin="0" end="3600" vehsPerHour="600" departLane="free" departSpeed="max"/>
    <flow id="flow_E_S" type="passenger_car" route="r_E_S" begin="0" end="3600" vehsPerHour="600" departLane="free" departSpeed="max"/>
    <flow id="flow_S_N" type="passenger_car" route="r_S_N" begin="0" end="3600" vehsPerHour="500" departLane="free" departSpeed="max"/>
    <flow id="flow_S_W" type="passenger_car" route="r_S_W" begin="0" end="3600" vehsPerHour="360" departLane="free" departSpeed="max"/>

</routes>
