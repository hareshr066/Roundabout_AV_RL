<?xml version="1.0" encoding="UTF-8"?>
<routes xmlns:xsi="http://www.w3.org/2001/XMLSchema-instance" xsi:noNamespaceSchemaLocation="http://sumo.dlr.de/xsd/routes_file.xsd">
    <!-- Human-Driven Vehicle (HDV) type: Krauss model with human driver imperfection (sigma=0.5) -->
    <vType id="passenger_car" 
           carFollowModel="Krauss" 
           length="5.0" 
           minGap="2.5" 
           maxSpeed="13.89" 
           accel="2.6" 
           decel="4.5" 
           sigma="0.5" 
           tau="1.0"
           guiShape="passenger"
           color="0.8,0.8,0.8"/> <!-- Light Grey -->

    <!-- Autonomous Vehicle (AV) type: IDM model, no driver imperfections (sigma=0), green color -->
    <vType id="av_car" 
           carFollowModel="IDM" 
           length="5.0" 
           minGap="2.0" 
           maxSpeed="13.89" 
           accel="2.0" 
           decel="4.5" 
           tau="0.8"
           guiShape="passenger/sedan" 
           color="0,1,0"/> <!-- Green -->

    <!-- Requested Route Definitions -->
    <route id="r_N_E" edges="entry_N circ_N_W circ_W_S circ_S_E exit_E"/>
    <route id="r_N_S" edges="entry_N circ_N_W circ_W_S exit_S"/>
    <route id="r_W_S" edges="entry_W circ_W_S exit_S"/>
    <route id="r_E_N" edges="entry_E circ_E_N exit_N"/>
    
    <!-- Additional helper routes for background flow balance -->
    <route id="r_W_N" edges="entry_W circ_W_S circ_S_E circ_E_N exit_N"/>
    <route id="r_E_S" edges="entry_E circ_E_N circ_N_W circ_W_S exit_S"/>

    <!-- Vehicle Flows (defaulting to passenger_car, will be dynamically modified by environment via TraCI) -->
    <flow id="flow_N_E" type="passenger_car" route="r_N_E" begin="0" end="3600" vehsPerHour="150"/>
    <flow id="flow_N_S" type="passenger_car" route="r_N_S" begin="0" end="3600" vehsPerHour="150"/>
    <flow id="flow_W_S" type="passenger_car" route="r_W_S" begin="0" end="3600" vehsPerHour="150"/>
    <flow id="flow_E_N" type="passenger_car" route="r_E_N" begin="0" end="3600" vehsPerHour="150"/>
    <flow id="flow_W_N" type="passenger_car" route="r_W_N" begin="0" end="3600" vehsPerHour="100"/>
    <flow id="flow_E_S" type="passenger_car" route="r_E_S" begin="0" end="3600" vehsPerHour="100"/>
</routes>
